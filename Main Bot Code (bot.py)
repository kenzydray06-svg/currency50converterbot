# ============ CURRENCY DATA ============
# Currency symbols for display
CURRENCY_SYMBOLS = {
    'USD': '$', 'EUR': '€', 'GBP': '£', 'JPY': '¥',
    'CNY': '¥', 'INR': '₹', 'CAD': 'C$', 'AUD': 'A$',
    'CHF': 'Fr', 'NZD': 'NZ$', 'KRW': '₩', 'RUB': '₽',
    'BRL': 'R$', 'MXN': '$', 'SGD': 'S$', 'HKD': 'HK$',
    'SEK': 'kr', 'NOK': 'kr', 'DKK': 'kr', 'PLN': 'zł',
    'TRY': '₺', 'THB': '฿', 'IDR': 'Rp', 'MYR': 'RM',
    'PHP': '₱', 'VND': '₫', 'AED': 'د.إ', 'SAR': 'ر.س',
    'ZAR': 'R', 'NGN': '₦', 'EGP': 'E£', 'KWD': 'KD',
}

# Common currencies for display
COMMON_CURRENCIES = ['USD', 'EUR', 'GBP', 'JPY', 'CNY', 'INR', 'CAD', 'AUD', 'CHF', 'NZD']

# ============ CACHE ============
rate_cache = {
    'data': None,
    'timestamp': None,
    'base': None
}

def get_exchange_rates(base: str = 'USD') -> Optional[Dict]:
    """Fetch exchange rates with caching"""
    current_time = datetime.now()
    
    # Check cache
    if (rate_cache['data'] and 
        rate_cache['timestamp'] and 
        rate_cache['base'] == base):
        
        elapsed = (current_time - rate_cache['timestamp']).total_seconds()
        if elapsed < 3600:  # 1 hour cache
            logger.debug(f"Using cached rates for {base}")
            return rate_cache['data']['rates']
    
    # Fetch new rates
    try:
        logger.info(f"Fetching rates for {base}...")
        response = requests.get(f"{CURRENCY_API}{base}", timeout=10)
        
        if response.status_code == 200:
            data = response.json()
            rate_cache['data'] = data
            rate_cache['timestamp'] = current_time
            rate_cache['base'] = base
            logger.info(f"Successfully fetched rates for {base}")
            return data['rates']
        else:
            logger.error(f"API error: {response.status_code}")
            return None
            
    except Exception as e:
        logger.error(f"Error fetching rates: {e}")
        # Return cached data if available
        if rate_cache['data']:
            logger.warning("Using stale cache")
            return rate_cache['data']['rates']
        return None

def convert_currency(amount: float, from_curr: str, to_curr: str) -> Optional[float]:
    """Convert currency"""
    try:
        rates = get_exchange_rates(from_curr)
        if not rates or to_curr not in rates:
            return None
        
        result = amount * rates[to_curr]
        return round(result, 2)
    except Exception as e:
        logger.error(f"Conversion error: {e}")
        return None

def get_symbol(currency: str) -> str:
    """Get currency symbol"""
    return CURRENCY_SYMBOLS.get(currency, currency)

def format_number(num: float) -> str:
    """Format number with commas"""
    if num == int(num):
        return f"{num:,.0f}"
    return f"{num:,.2f}"

