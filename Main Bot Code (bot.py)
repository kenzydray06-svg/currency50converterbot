async def convert(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Handle /convert command"""
    try:
        args = context.args
        
        if len(args) != 3:
            await update.message.reply_text(
                "❌ **Invalid format!**\n\n"
                "Use: `/convert [amount] [from] [to]`\n"
                "Example: `/convert 100 USD EUR`",
                parse_mode='Markdown'
            )
            return
        
        # Parse amount
        try:
            amount = float(args[0])
        except ValueError:
            await update.message.reply_text(
                f"❌ Invalid amount: '{args[0]}'\n"
                "Please enter a valid number.",
                parse_mode='Markdown'
            )
            return
        
        from_curr = args[1].upper()
        to_curr = args[2].upper()
        
        # Convert
        result = convert_currency(amount, from_curr, to_curr)
        
        if result is None:
            await update.message.reply_text(
                f"❌ Conversion failed!\n\n"
                f"Please check currency codes: {from_curr} → {to_curr}\n"
                "Use /list to see supported currencies.",
                parse_mode='Markdown'
            )
            return
        
        # Format response
        from_symbol = get_symbol(from_curr)
        to_symbol = get_symbol(to_curr)
        rate = result / amount
        
        response = f"""
💱 **Conversion Result**

{format_number(amount)} {from_symbol} ({from_curr}) = **{format_number(result)}** {to_symbol} ({to_curr})

📊 Rate: 1 {from_curr} = {format_number(rate)} {to_curr}
🕐 Updated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}
        """
        
        await update.message.reply_text(response, parse_mode='Markdown')
        logger.info(f"Converted {amount} {from_curr} to {to_curr}")
        
    except Exception as e:
        logger.error(f"Convert error: {e}")
        await update.message.reply_text(
            "❌ An error occurred. Please try again later."
        )

async def rates(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Handle /rates command"""
    try:
        rates_data = get_exchange_rates()
        if not rates_data:
            await update.message.reply_text(
                "❌ Unable to fetch rates. Please try again later."
            )
            return
        
        response = "📈 **Current Exchange Rates**\n\n"
        response += f"Base: USD\n\n"
        
        for currency in COMMON_CURRENCIES:
            if currency in rates_data:
                rate = rates_data[currency]
                symbol = get_symbol(currency)
                response += f"• {symbol} {currency}: {format_number(rate)}\n"
        
        response += f"\n🕐 {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}"
        
        await update.message.reply_text(response, parse_mode='Markdown')
        
    except Exception as e:
        logger.error(f"Rates error: {e}")
        await update.message.reply_text("❌ An error occurred. Please try again later.")

async def list_currencies(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Handle /list command"""
    try:
        rates_data = get_exchange_rates()
        if not rates_data:
            await update.message.reply_text(
                "❌ Unable to fetch currencies. Please try again later."
            )
            return
        
        currencies = sorted(rates_data.keys())
        
        response = f"📋 **Supported Currencies**\n\n"
        response += f"Total: {len(currencies)} currencies\n\n"
        
        # Show first 50 currencies
        shown = currencies[:50]
        response += "• " + "\n• ".join(shown)
        
        if len(currencies) > 50:
            response += f"\n\n... and {len(currencies) - 50} more currencies"
        
        response += "\n\n💡 Use /convert to convert currencies"
        
        await update.message.reply_text(response, parse_mode='Markdown')
        
    except Exception as e:
        logger.error(f"List error: {e}")
        await update.message.reply_text("❌ An error occurred. Please try again later.")

async def inline_query(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Handle inline queries"""
    query = update.inline_query.query.strip()
    
    if not query:
        # Show help
        results = [
            InlineQueryResultArticle(
                id="1",
                title="💱 Currency Converter",
                description="Type: 100 USD EUR",
                input_message_content=InputTextMessageContent(
                    "📝 **Usage:**\n"
                    "Type `100 USD EUR` to convert\n"
                    "Example: `50 GBP JPY`",
                    parse_mode='Markdown'
                )
            )
        ]
        await update.inline_query.answer(results)
        return
    
    parts = query.split()
    
    if len(parts) != 3:
        results = [
            InlineQueryResultArticle(
                id="1",
                title="❌ Invalid format",
                description="Use: [amount] [from] [to]",
                input_message_content=InputTextMessageContent(
                    "❌ **Invalid format!**\n\n"
                    "Use: `[amount] [from] [to]`\n"
                    "Example: `100 USD EUR`",
                    parse_mode='Markdown'
                )
            )
        ]
        await update.inline_query.answer(results)
        return
    
    try:
        amount = float(parts[0])
        from_curr = parts[1].upper()
        to_curr = parts[2].upper()
        
        result = convert_currency(amount, from_curr, to_curr)
        
        if result is None:
            results = [
                InlineQueryResultArticle(
                    id="1",
                    title="❌ Invalid currency",
                    description="Please check currency codes",
                    input_message_content=InputTextMessageContent(
                        "❌ **Invalid currency!**\n\n"
                        "Please use valid 3-letter currency codes.\n"
                        "Example: `100 USD EUR`",
                        parse_mode='Markdown'
                    )
                )
            ]
            await update.inline_query.answer(results)
            return
        
        # Success
        from_symbol = get_symbol(from_curr)
        to_symbol = get_symbol(to_curr)
        
        result_text = f"💱 {format_number(amount)} {from_symbol} = {format_number(result)} {to_symbol}"
        
        results = [
            InlineQueryResultArticle(
                id="1",
                title=result_text,
                description=f"Rate: 1 {from_curr} = {format_number(result/amount)} {to_curr}",
                input_message_content=InputTextMessageContent(
                    f"{result_text}\n\n"
                    f"📊 Rate: 1 {from_curr} = {format_number(result/amount)} {to_curr}\n"
                    f"🕐 {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}"
                )
            )
        ]
        
        await update.inline_query.answer(results)
        logger.info(f"Inline: {amount} {from_curr} → {to_curr}")
        
    except ValueError:
        results = [
            InlineQueryResultArticle(
                id="1",
                title="❌ Invalid amount",
                description="Please enter a valid number",
                input_message_content=InputTextMessageContent(
                    "❌ **Invalid amount!**\n\n"
                    "Please enter a valid number.\n"
                    "Example: `100 USD EUR`",
                    parse_mode='Markdown'
                )
            )
        ]
        await update.inline_query.answer(results)
    except Exception as e:
        logger.error(f"Inline error: {e}")

async def error_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Handle errors"""
    logger.error(f"Update {update} caused error {context.error}")
    if update and update.effective_message:
        await update.effective_message.reply_text(
            "❌ An error occurred. Please try again later."
        )

# ============ MAIN ============

def main():
    """Start the bot"""
    logger.info("🚀 Starting Currency50 Converter Bot...")
    logger.info(f"Bot token: {'✓' if TOKEN else '✗'}")
    
    # Create application
    app = Application.builder().token(TOKEN).build()
    
    # Add handlers
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("help", help_command))
    app.add_handler(CommandHandler("convert", convert))
    app.add_handler(CommandHandler("rates", rates))
    app.add_handler(CommandHandler("list", list_currencies))
    app.add_handler(InlineQueryHandler(inline_query))
    app.add_error_handler(error_handler)
    
    logger.info("✅ Bot is ready!")
    logger.info("📱 Bot username: @currency50converterbot")
    logger.info("🔄 Starting polling...")
    
    # Start polling
    app.run_polling(allowed_updates=Update.ALL_TYPES)

if __name__ == '__main__':
    main()
